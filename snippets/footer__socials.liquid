<ul class="" role="list">
  {%- if settings.social_facebook_link != blank -%}
    <li class="social-icon">
      <a href="{{ settings.social_facebook_link }}" class="">
        <span class="icon-5">
          {{- 'icon__facebook.svg' | inline_asset_content -}}
        </span>
        <span class="sr-only">{{ 'general.social.links.facebook' | t }}</span>
      </a>
    </li>
  {%- endif -%}
