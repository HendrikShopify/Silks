<label
  for="{{ id }}"
  title="{{ value }}"
  class="cursor-pointer"
>
  <input
    type="{{ type | default: 'radio' }}"
    id="{{ id }}"
    name="{{ name }}"
    value="{{ value }}"
    form="{{ product_form_id }}"
    class="hidden peer"
    {% if checked %}
      checked
    {% endif %}
    {% comment %}
      {% if option_disabled %}
        disabled
      {% endif %}
    {% endcomment %}
    {% if additional_props %}
      {{ additional_props }}
    {% endif %}
  >

  {%- liquid
    assign swatch_value = null
    if swatch.image
      assign image_url = swatch.image | image_url: width: 50
      assign swatch_value = 'url(' | append: image_url | append: ')'
      assign swatch_focal_point = swatch.image.presentation.focal_point
    elsif swatch.color
      assign swatch_value = 'rgb(' | append: swatch.color.rgb | append: ')'
      if swatch.color.rgb == '255 255 255' or swatch.color == 'white'
        assign swatch_border = 'border: 1px solid #ccc;'
      endif
    endif
  -%}

  <span
    class="
      variant__swatch
       {% if option_disabled %}
        variant__swatch-disabled
      {% endif %}
    "
    {% if swatch_value %}
      style="background: {{ swatch_value }}; {{ swatch_border }}"
    {% endif %}
  ></span>

  {{ help_text }}
</label>
