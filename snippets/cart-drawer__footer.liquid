<div class="px-8 py-6  bg-gray-50">
  <div class="space-y-5 mb-6">
    {% render 'cart-drawer__totals' %}
  </div>

  <div>
    <button
      type="submit"
      class="btn w-full"
      name="checkout"
      form="cart-drawer-form"
