<div
  class="fixed inset-0 z-50 flex items-stretch justify-end"
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'general.search.search' | t }}"
>
  <div data-modal-overlay class="absolute inset-0 bg-black opacity-20"></div>
  <div
    data-search-modal
    class="z-10 bg-white w-full h-full max-w-md flex flex-col items-stretch justify-between"
    tabindex="-1"
  >
    <predictive-search class="flex flex-col h-full" data-loading-text="{{ 'accessibility.loading' | t }}">
      <form action="{{ routes.search_url }}" method="get" role="search" class="flex flex-col flex-grow h-full">
        <div class="flex w-full py-6 px-8 justify-between items-center gap-4">
          <button
            type="button"
            class="h-5 w-5"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            <span class="icon-5">
              {{- 'icon__close.svg' | inline_asset_content -}}
            </span>
          </button>
          {% render 'search__input' %}
        </div>

        <div
          class="overflow-y-auto flex-grow min-h-0 p-6"
          tabindex="-1"
          data-predictive-search
        ></div>

        <span class="predictive-search-status sr-only" role="status" aria-hidden="true"></span>
      </form>
    </predictive-search>
  </div>
</div>
