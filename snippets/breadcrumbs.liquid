{%- unless template == 'index' or template == 'cart' or template == 'list-collections' or template == '404' -%}
  {%- assign t = template | split: '.' | first -%}

  <div class="container py-6">
    <nav class="" role="navigation" aria-label="breadcrumbs">
      <ol class="flex list-none p-0">
        <li class="inline-flex items-center">
          <a class="hover:underline" href="/">Home</a>
        </li>
        {%- case t -%}
          {%- when 'page' -%}
            <li class="inline-flex items-center">
              <span class="mx-2">/</span>
              <a class="text-gray-900 hover:underline" href="{{ page.url }}" aria-current="page">
                {{- page.title -}}
              </a>
            </li>
          {%- when 'product' -%}
            {%- if collection.url -%}
              <li class="inline-flex items-center">
                <span class="mx-2 text-gray-400">/</span>
                <a class="underline hover:no-underline" href="{{ collection.url }}">
                  {{- collection.title -}}
                </a>
              </li>
            {%- endif -%}
            <li class="inline-flex items-center">
              <span class="mx-2 text-gray-400">/</span>
              <a class="hover:underline" href="{{ product.url }}" aria-current="page">
                {{- product.title -}}
              </a>
            </li>
          {%- when 'collection' and collection.handle -%}
            {%- if current_tags -%}
              <li class="inline-flex items-center">
                <span class="mx-2 text-gray-400">/</span>
                <a class="hover:no-underline" href="{{ collection.url }}">
                  {{- collection.title -}}
                </a>
              </li>
              <li class="inline-flex items-center">
                <span class="mx-2 text-gray-400">/</span>
                {%- capture tag_url -%}{{ collection.url }}/{{ current_tags | join: "+" }}{%- endcapture -%}
                <a class="text-gray-900 hover:underline" href="{{ tag_url }}" aria-current="page">
                  {{- current_tags | join: ' + ' -}}
                </a>
              </li>
            {%- else -%}
              <li class="inline-flex items-center">
                <span class="mx-2 text-gray-400">/</span>
                <a class="text-gray-900 hover:underline" href="{{ collection.url }}" aria-current="page">
                  {{- collection.title -}}
                </a>
              </li>
            {%- endif -%}
          {%- when 'blog' -%}
            {%- if current_tags -%}
              <li class="inline-flex items-center">
                <span class="mx-2 text-gray-400">/</span>
                <a class="hover:underline" href="{{ blog.url }}">{{ blog.title }}</a>
              </li>
              <li class="inline-flex items-center">
                <span class="mx-2 text-gray-400">/</span>
                {%- capture tag_url -%}{{ blog.url }}/tagged/{{ current_tags | join: "+" }}{%- endcapture -%}
                <a class="text-gray-900 hover:underline" href="{{ tag_url }}" aria-current="page">
                  {{- current_tags | join: ' + ' -}}
                </a>
              </li>
            {%- else -%}
              <li class="inline-flex items-center">
                <span class="mx-2 text-gray-400">/</span>
                <a class="text-gray-900 hover:underline" href="{{ blog.url }}" aria-current="page">
                  {{- blog.title -}}
                </a>
              </li>
            {%- endif -%}
          {%- when 'article' -%}
            <li class="inline-flex items-center">
              <span class="mx-2 text-gray-400">/</span>
              <a class="hover:underline" href="{{ blog.url }}">{{ blog.title }}</a>
            </li>
            <li class="inline-flex items-center">
              <span class="mx-2 text-gray-400">/</span>
              <a class="text-gray-900 hover:underline" href="{{ article.url }}" aria-current="page">
                {{- article.title -}}
              </a>
            </li>
          {%- else -%}
            <li class="inline-flex items-center">
              <span class="mx-2 text-gray-400">/</span>
              <a class="text-gray-900 hover:underline" href="{{ request.path }}" aria-current="page">
                {{- page_title -}}
              </a>
            </li>
        {%- endcase -%}
      </ol>
    </nav>
  </div>
{%- endunless -%}
