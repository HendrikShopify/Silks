<li
  class="grid sm:flex flex-col sm:flex-row flex-nowrap grid-cols-1 sm:grid-cols-2 grid-rows-[auto] sm:grid-rows-[auto] auto-cols-[1fr] sm:auto-cols-[1fr] gap-x-5 sm:gap-x-8 gap-y-5 sm:gap-y-8 justify-start items-center max-w-175 mx-auto md:mx-0"
  data-cart-item
  id="CartItem-{{ item.index | plus: 1 }}"
>
  {% if item.image %}
    <a href="{{ item.url }}" class="block shrink-0">
      <img
        class="block aspect-[2.1/1.7] rounded-[28px] w-full sm:w-[214px] object-cover"
        src="{{ item.image | image_url: width: 600 }}"
        alt="{{ item.image.alt | escape }}"
        width="214"
        height="171"
        loading="lazy"
      >
    </a>
  {% endif %}

  <div class="flex flex-col gap-x-8 sm:gap-x-12 gap-y-8 sm:gap-y-12 w-full">
    <div class="flex flex-col gap-4">
      <h2 class="leading-[1.2em!important]">
        <a href="{{ item.url }}">{{ item.product.title | escape }}</a>
        {%- for option in item.options_with_values -%}
          {%- assign option_name_down = option.name | downcase -%}
          {%- if option_name_down == 'size' -%}
            - {{ option.value }}
          {%- endif -%}
        {%- endfor -%}
      </h2>

      {%- for option in item.options_with_values -%}
        {%- assign option_name_down = option.name | downcase -%}
        {%- if option_name_down contains 'color' or option_name_down contains 'colour' -%}
          {%- liquid
            assign swatch_style = null
            for product_option in item.product.options_with_values
              if product_option.name == option.name
                for value in product_option.values
                  if value.name == option.value
                    if value.swatch.image
                      assign swatch_image = value.swatch.image | image_url: width: 32
                      assign swatch_style = 'background-image: url(' | append: swatch_image | append: '); background-size: cover;'
                    elsif value.swatch.color
                      assign swatch_style = 'background-color: rgb(' | append: value.swatch.color.rgb | append: ');'
                    endif
                  endif
                endfor
              endif
            endfor
          -%}
          <div class="flex gap-2 items-center">
            <div
              class="rounded-[999px] size-4 shrink-0 {% unless swatch_style %}bg-[#9a9487]{% endunless %}"
              {% if swatch_style %}
                style="{{ swatch_style }}"
              {% endif %}
            ></div>
            <p class="leading-[1.2em]">{{ option.value }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="flex justify-between items-center gap-4">
      <div class="leading-[1.2em!important] text-[#4f4a45]">
        {% render 'cart-line-item__price', item: item %}
        {% render 'cart-line-item__discounts', item: item %}
      </div>

      {% render 'cart-page-line-item__quantity', item: item %}
    </div>
  </div>
</li>
