{% comment %}
  <footer class="bg-gray-50 pt-25">
    <div class="container">
      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-3">
          {% render 'newsletter' %}
        </div>

        <div class="col-span-12 flex flex-row  gap-35 md:col-span-6">
          {% render 'footer__linklist' %}
          {% render 'footer__linklist' %}
          <div>
            {% render 'footer__socials' %}
          </div>
        </div>

        <div class="col-span-12 flex gap-4 text-sm pb-3 mt-20">
          <div>&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url }}</div>
          <nav class="inline-flex" aria-label="Footer Links">
            <ul class="flex gap-4 ">
              <li>
                <a href="{{ shop.privacy_policy.url }}">{{ 'general.policies.privacy_policy' | t }}</a>
              </li>
              <li>
                <a href="{{ shop.terms_of_service.url }}">{{ 'general.policies.terms_of_service' | t }}</a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </div>
  </footer>
{% endcomment %}

<footer class="pt-[15px] sm:pt-10 pr-[15px] sm:pr-10 pb-[15px] sm:pb-10 pl-[15px] sm:pl-10 text-neutral-100 [background-image:linear-gradient(180deg,_hsla(35.999999999999794,_18.52%,_94.71%,_1.00),_#d7d0c8)]">
  <div class="relative pt-[50px] sm:pt-20 lg:pt-[150px] pr-[30px] sm:pr-[50px] lg:pr-[105px] pb-[50px] sm:pb-20 lg:pb-[150px] pl-[30px] sm:pl-[50px] lg:pl-[105px] rounded-4xl w-full overflow-hidden">
    <div class="flex relative flex-row flex-wrap gap-x-5 gap-y-15 justify-between z-[1]">
      <div class="max-w-[349px]">
        <a href="{{ routes.root_url }}" class="block">
          <span class="sr-only">{{ shop.name }}</span>
          <img
            class="mb-10 w-full sm:w-auto max-w-[187px]"
            src="{{ 'logo-white.svg' | asset_url }}"
            width="187"
            height="40"
            alt="{{ shop.name }}"
          >
        </a>
        <p>{{ section.settings.description }}</p>
      </div>
      <div class="grid md:flex flex-row flex-wrap grid-cols-2 md:grid-cols-none grid-rows-[auto_auto] md:grid-rows-none auto-cols-[1fr] md:auto-cols-auto gap-x-[25px] sm:gap-x-[90px] md:gap-x-[90px] gap-y-[25px] sm:gap-y-[90px] md:gap-y-[90px] w-full md:w-auto">
        {% for block in section.blocks %}
          {% if block.type == 'Menu' %}
            <div>
              <h2 class="mb-[25px] text-xl font-playfair">{{ block.settings.link_list.title }}</h2>
              <ul class="flex flex-col flex-nowrap gap-[11px]">
                {% for link in block.settings.link_list.links %}
                  <li>
                    <a href="{{ link.url }}">{{ link.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <img
      class="absolute inset-[0%] size-full object-cover"
      src="{{ section.settings.bg | image_url: width: 1800 }}"
      srcset="
        {{ section.settings.bg | image_url: width: 450 }} 450w,
        {{ section.settings.bg | image_url: width: 900 }} 900w,
        {{ section.settings.bg | image_url: width: 1206 }} 1206w,
        {{ section.settings.bg | image_url: width: 1800 }} 1800w
      "
      sizes="(max-width: 900px) 450px, (max-width: 1206px) 900px, (max-width: 1800px) 1206px, 1800px"
    >
  </div>
  <div class="flex justify-center items-center mt-5 pt-5 sm:pt-0 pb-5 sm:pb-0 rounded-[100px] h-auto sm:h-25 bg-neutral-900">
    <ul class="flex flex-row flex-wrap md:flex-nowrap gap-x-[25px] md:gap-x-[50px] gap-y-3 sm:gap-y-[25px] md:gap-y-[50px] justify-center items-center pr-3 sm:pr-0 pl-3 sm:pl-0 w-full md:w-auto">
      {% assign menu = linklists[section.settings.legal_links] %}

      {% for link in menu.links %}
        <li>
          <a href="{{ link.url }}">{{ link.title }}</a>
        </li>
      {% endfor %}
    </ul>
  </div>
</footer>

<!-- Section Settings -->
{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A refined collection designed to elevate the everyday. Each piece blends performance and elegance, made to move effortlessly with you, wherever the day takes you."
    },
    {
      "type": "image_picker",
      "id": "bg",
      "label": "bg"
    },
    {
      "type": "link_list",
      "id": "legal_links",
      "label": "Legal Links"
    }
  ],
  "blocks": [
    {
      "type": "Menu",
      "name": "Menu",
      "settings": [
        {
          "type": "link_list",
          "id": "link_list",
          "label": "Link List"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ],
  "max_blocks": 4
}
{% endschema %}
