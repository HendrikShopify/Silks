<header class="bg-gray-50">
  <div class="container py-4">
    <div class="grid grid-cols-3 h-16">
      <div class="flex flex-row gap-2">
        <div class="">
          {% render 'header__logo' %}
        </div>
      </div>
      <div class="flex flex-row justify-center items-center"></div>
      <div class="flex flex-row gap-6 justify-end items-center">
        {% render 'language-localization' %}
        <div class="flex flex-row">
          {% render 'header__search' %}
          {% render 'header__account' %}
          {% render 'wishlist__link' %}
          {% render 'header__cart' %}
        </div>
      </div>
    </div>
  </div>
</header>
