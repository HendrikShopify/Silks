{%- assign product_form_id = 'product-form-' | append: section.id -%}

{% render 'breadcrumbs' %}

<product-info
  id="MainProduct-{{ section.id }}"
  class=""
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
>
  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

  <div class="container default-grid py-8">
    <div class="col-span-6">
      {% render 'product__media-slider', product: product %}
    </div>

    <div class="col-span-6 md:px-25 flex flex-col gap-10 py-30">
      <div class="flex flex-col gap-2">
        <div class="flex justify-between">
          <h1 class="h3">{{ product.title }} heu</h1>
          {% render 'wishlist__button' %}
        </div>
        {% render 'card-product__price' %}
      </div>

      {% for block in section.blocks %}
        {% if block.type == '@app' %}
          {% render block %}
        {% endif %}
      {% endfor %}

      {% render 'selling_plans', product: product, product_form_id: product_form_id, section_id: section.id %}

      <div class="flex flex-col gap-8">
        {% render 'product__variant-picker', product: product, product_form_id: product_form_id %}

        <div class="flex gap-1">
          {% render 'product__quantity-input', product: product, product_form_id: product_form_id %}
          {%- render 'product__form', product: product, product_form_id: product_form_id, section_id: section.id -%}
        </div>
      </div>
    </div>
  </div>
</product-info>

<script type="application/ld+json">
  {{ product | structured_data }}
</script>

{% comment %}
  {% schema %}
  {
    "name": "Custom Section",
    "blocks": [
      {
        "type": "@app"
      }
    ],
    "presets": [
      {
        "name": "Custom Section"
      }
    ]
  }
  {% endschema %}
{% endcomment %}
